# ReflectAI Environment Configuration Example
# Copy this file to .env and fill in the values

# Express Backend Server Configuration
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_minimum_32_characters_long

# Firebase Admin SDK Configuration (for Backend Server authentication)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-firebase-project-id.iam.gserviceaccount.com
# Private key should be single-line with newline characters \n replaced
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQ...\n-----END PRIVATE KEY-----\n"

# Client Firebase Configuration (for client-side reference if needed)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=1234567890
FIREBASE_APP_ID=1:1234567890:web:abcdef123456
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Gemini API Configuration
GEMINI_API_KEY=your-google-gemini-api-key

# Kiwi LLM API Configuration
KIWI_API_URL=https://api.kiwi-llm.example.com/v1
KIWI_API_KEY=your-kiwi-llm-api-key
